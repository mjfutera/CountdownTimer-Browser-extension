{
  "name": "countdowns-chrome-extension",
  "version": "1.1.3",
  "private": true,
  "description": "Countdown timer Chrome extension - quality tooling",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "node --test",
    "ci": "npm run lint ; npm run format ; npm run test",
    "package": "powershell -ExecutionPolicy Bypass -File ./tools/package-extension.ps1"
  },
  "devDependencies": {
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3"
  }
}
