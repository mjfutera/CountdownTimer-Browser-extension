{
  "type": "module",
  "name": "countdowns-chrome-extension",
  "version": "1.2.0",
  "description": "Countdown timer Chrome extension",
  "private": true,
  "scripts": {
    "lint": "eslint modules/ tests/",
    "lint:fix": "eslint --fix modules/ tests/",
    "format": "prettier --write modules/ tests/",
    "format:check": "prettier --check modules/ tests/",
    "test": "jest --coverage",
    "ci": "npm run lint && npm run format:check && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
